{
  "name": "odlingskalender-portable",
  "version": "1.0.0",
  "description": "Portabel Windows-wrapper for Odlingskalender.",
  "author": "Bjorkbacka",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "se.bjorkbacka.odlingskalender.portable",
    "productName": "Odlingskalender Portable",
    "directories": {
      "output": "dist"
    },
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../index.html",
        "to": "web/index.html"
      },
      {
        "from": "../app.js",
        "to": "web/app.js"
      },
      {
        "from": "../styles.css",
        "to": "web/styles.css"
      },
      {
        "from": "../seed_catalog_full.js",
        "to": "web/seed_catalog_full.js"
      },
      {
        "from": "../vendor",
        "to": "web/vendor"
      },
      {
        "from": "../assets",
        "to": "web/assets"
      },
      {
        "from": "../bjorkbacka-mark.svg",
        "to": "web/bjorkbacka-mark.svg"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    }
  }
}
